{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/decision-logs",
      "destination": "/api/decision-logs.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "data/**"
    },
    "api/decision-logs.ts": {
      "maxDuration": 15
    }
  }
}
